# ─────────────────────────────────────────────────────────────
# Career Ladder — environment variables
# Copy this file to .env.local and fill in the values.
# ─────────────────────────────────────────────────────────────

# ── Snowflake (required) ──
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=CAREER_LADDER
SNOWFLAKE_SCHEMA=PUBLIC

# ── Auth (required) ──
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── AI: Perplexity (enables parsing, generation & live research) ──
PERPLEXITY_API_KEY=
# PERPLEXITY_MODEL=sonar-pro       # optional override
# PERPLEXITY_DAILY_CAP=50          # optional global daily request cap

# ── Payments: Razorpay (enables paid subscriptions) ──
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Email: Resend (enables OTP + notification emails) ──
RESEND_API_KEY=

# ── Cron protection (protects scheduled routes) ──
CRON_SECRET=
